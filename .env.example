# GitHub OAuth App credentials.
# Create at https://github.com/settings/developers → New OAuth App.
# Authorization callback URL: http://localhost:5173/auth/github/callback (dev)
#                             https://withsigil.eu/auth/github/callback (prod)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Shared KV file for the dev ws sidecar + Fresh process. Unset in prod (Deno
# Deploy provides managed KV).
SIGIL_KV_PATH=./.sigil-kv
